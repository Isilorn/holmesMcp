# ── Outils dev locaux — non committés (scripts sudo, déploiement local) ───────
dev/

# ── Credentials et secrets — JAMAIS dans le repo (D11.8, ADR-0013) ───────────
.env
.env.*
*.creds
*credentials*.json
*secret*.json
secrets.cfg
*apikey*
*.pem
*.key
*.p12

# Fixtures réelles (hors repo — workspace local Claude Code uniquement)
tests/fixtures/real/
tests/live/fixtures/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
*.egg-info/
dist/
build/
.eggs/

# Venv Jeedom (généré par dependancy_install côté box)
resources/venv/

# ── Jeedom runtime (artefacts locaux box) ─────────────────────────────────────
/tmp/
*.pid

# ── Tests / couverture ────────────────────────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/
.ruff_cache/

