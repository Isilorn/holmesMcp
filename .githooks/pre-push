#!/usr/bin/env bash
# pre-push : second scan avant push GitHub (ADR-0013, D11.8)
# Scanne les commits depuis origin (ou depuis le début si première push).
# Exclusion : tests/ — les fixtures synthétiques utilisent des IPs/tokens fictifs (RFC 5737).

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

BLOCKED=0

# Commits à pousser
REMOTE="$1"
RANGE=""

while read -r local_ref local_sha remote_ref remote_sha; do
    if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
        RANGE="$local_sha"
    else
        RANGE="$remote_sha..$local_sha"
    fi
done

if [ -z "$RANGE" ]; then
    exit 0
fi

# Contenu des commits à pousser — hors tests/ (fixtures synthétiques intentionnelles)
CONTENT=$(git log "$RANGE" -p -- ':!tests/' 2>/dev/null || true)

scan_content() {
    local label="$1"
    local pattern="$2"
    local matches
    matches=$(echo "$CONTENT" | grep -nE "^\\+.*$pattern" || true)
    if [ -n "$matches" ]; then
        echo -e "${RED}[BLOQUÉ]${NC} Pattern sensible dans les commits : ${YELLOW}$label${NC}"
        echo "$matches" | head -5
        BLOCKED=1
    fi
}

scan_content "IP privée concrète" \
    '(192\.168\.[0-9]{1,3}\.[0-9]{1,3}|10\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3})'

scan_content "Token/apikey concret" \
    '(apikey|api_key|token|secret)["\s]*[:=]["\s]*[A-Za-z0-9+/]{20,}'

scan_content "Mot de passe concret" \
    '(password|passwd|pwd)["\s]*[:=]["\s]*[^\s<>{}\[\]]{6,}'

if [ "$BLOCKED" -eq 1 ]; then
    echo ""
    echo -e "${RED}Push bloqué — credential potentiel dans les commits.${NC}"
    echo "Procédure leak : rewrite git history + force push + rotation credential."
    echo "Voir ADR-0013 § procédure de réponse rapide."
    exit 1
fi

exit 0
